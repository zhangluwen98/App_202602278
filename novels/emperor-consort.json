            }
          ]
        },
        {
          "id": "p2-31",
          "parts": [
            {
              "type": "narration",
              "text": "我握住他的手，他的手很凉，却很柔软。"
            },
            {
              "type": "dialogue",
              "speaker": "赵闻珂（我）",
              "text": "我知道这对你来说不容易，但我会等你。"
            },
            {
              "type": "dialogue",
              "speaker": "顾宴清",
              "text": "陛下..."
            },
            {
              "type": "dialogue",
              "speaker": "赵闻珂（我）",
              "text": "无论多久，我都等你。"
            }
          ],
          "choices": [
            {
              "id": "c2_p31_end",
              "text": "结束本章",
              "nextParagraphs": []
            }
          ]
        },
        {
          "id": "p2-32",
          "parts": [
            {
              "type": "narration",
              "text": "我轻轻拍着他的背，安慰着他。"
            },
            {
              "type": "dialogue",
              "speaker": "赵闻珂（我）",
              "text": "哭吧，哭出来就好了。"
            },
            {
              "type": "dialogue",
              "speaker": "顾宴清",
              "text": "陛下...我...我也喜欢你..."
            },
            {
              "type": "narration",
              "text": "他的声音哽咽，却充满了真诚。"
            }
          ],
